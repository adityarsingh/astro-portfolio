---
---

<section class="card hero">
  <div class="hero-grid">

    <div class="hero-text">
      <h1>Making content easier to find, manage, and scale.</h1>

      <p class="hero-bio">
        At Akamai, I work across AI agents, search strategy, and content ops
        to keep the website running well and ranking higher.
      </p>

      <div class="hero-actions">
        <a href="mailto:hello@adityarsingh.in" class="btn-primary">Get in touch →</a>
        <a href="/cv/aditya-cv.pdf" class="btn-outline" target="_blank" rel="noopener">Download CV</a>
      </div>
    </div>

    <div class="hero-photo-col">
      <img class="avatar-lg" src="/photos/profile.jpg" alt="Aditya Raj Singh" />
    </div>

  </div>
</section>

<style>
.hero {
  padding: 56px var(--card-px) 52px;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr 220px;
  gap: 80px;
  align-items: center;
}

.hero-text {
  display: flex;
  flex-direction: column;
  gap: 22px;
}

h1 {
  font-size: clamp(34px, 4vw, 52px);
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: -0.04em;
  color: var(--color-ink);
  max-width: 580px;
}

.hero-bio {
  font-size: 15px;
  line-height: 1.72;
  color: var(--color-body-text);
  max-width: 480px;
}

.hero-actions {
  display: flex;
  gap: 10px;
  align-items: center;
  flex-wrap: wrap;
  padding-top: 2px;
}

.hero-photo-col {
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-lg {
  width: 220px;
  height: 220px;
  border-radius: 50%;
  object-fit: cover;
  object-position: center 18%;
  background: var(--color-hairline);
  outline: 3px solid var(--color-hairline);
  outline-offset: 3px;
}

@media (max-width: 860px) {
  .hero-grid          { grid-template-columns: 1fr; gap: 36px; }
  .hero-photo-col     { order: -1; }
  .avatar-lg          { width: 160px; height: 160px; }
}

@media (max-width: 540px) {
  .hero      { padding: 32px 24px 28px; }
  .avatar-lg { width: 100px; height: 100px; }
}
</style>
