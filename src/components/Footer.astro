---
const year = new Date().getFullYear();
---

<footer class="footer">
  <p>© {year} Aditya Raj Singh</p>
  <div class="footer-links">
    <a href="https://linkedin.com/in/adityar-singh/" target="_blank" rel="noopener">LinkedIn</a>
    <a href="https://github.com/adityarsingh" target="_blank" rel="noopener">GitHub</a>
    <a href="/rss.xml">RSS</a>
  </div>
</footer>

<style>
.footer {
  padding: 26px 4px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
}

.footer p {
  font-size: 12px;
  color: var(--color-mute);
  letter-spacing: -0.01em;
}

.footer-links {
  display: flex;
  gap: 16px;
}

.footer-links a {
  font-size: 12px;
  color: var(--color-mute);
  text-decoration: none;
  letter-spacing: -0.01em;
  transition: color 0.1s;
}
.footer-links a:hover { color: var(--color-body-text); }
</style>
