---
const skills = [
  {
    num: '01',
    title: 'AI Automation',
    description: 'AI agents and automated workflows that turn hours of work into seconds.',
  },
  {
    num: '02',
    title: 'Website Ops',
    description: 'Keeping large sites running — performance, security, and content ops at scale.',
  },
  {
    num: '03',
    title: 'Digital Marketing',
    description: 'Tying analytics to action — finding what works and doubling down on it.',
  },
  {
    num: '04',
    title: 'SEO / GEO',
    description: 'Optimizing for search engines and how AI models answer questions.',
  },
];
---

<section class="card skills-card">
  <div class="skills-header">
    <span class="eyebrow">Expertise</span>
    <h2 class="section-title">What I do.</h2>
  </div>
  <div class="skills-grid">
    {skills.map((skill) => (
      <div class="skill-item">
        <span class="skill-num">{skill.num}</span>
        <span class="skill-name">{skill.title}</span>
        <p class="skill-desc">{skill.description}</p>
      </div>
    ))}
  </div>
</section>

<style>
.skills-card {
  overflow: hidden;
}

.skills-header {
  padding: 32px var(--card-px) 0;
}

.skills-grid {
  margin-top: 20px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid var(--color-hairline);
}

.skill-item {
  padding: 26px var(--card-px) 30px;
  border-right: 1px solid var(--color-hairline);
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: background-color 0.1s;
}
.skill-item:last-child { border-right: none; }
.skill-item:hover { background-color: var(--color-canvas-soft-2); }

.skill-num {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.07em;
  color: var(--color-mute);
}

.skill-name {
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: -0.02em;
  color: var(--color-ink);
}

.skill-desc {
  font-size: 13px;
  line-height: 1.6;
  color: var(--color-body-text);
}

@media (max-width: 700px) {
  .skills-grid            { grid-template-columns: repeat(2, 1fr); }
  .skill-item             { border-bottom: 1px solid var(--color-hairline); }
  .skill-item:nth-child(2n)  { border-right: none; }
  .skill-item:nth-child(n+3) { border-bottom: none; }
}

@media (max-width: 540px) {
  .skills-header { padding: 24px 24px 0; }
  .skill-item    { padding: 20px 24px 24px; }
}
</style>
