---
const navLinks = [
  { href: '/blog',   label: 'Writing'   },
  { href: '/photos', label: 'Photos'    },
];

const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <a href="/" class="nav-name">Aditya Raj Singh</a>

  <div class="nav-links">
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class:list={['nav-link', { 'nav-link-active': currentPath.startsWith(href) }]}
      >
        {label}
      </a>
    ))}
    <a href="mailto:hello@adityarsingh.in" class="nav-link">Contact</a>

    <button id="theme-toggle" class="theme-btn" aria-label="Toggle colour theme">
      <svg class="icon-moon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <svg class="icon-sun" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
    </button>
  </div>

  <!-- Mobile hamburger -->
  <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false" id="hamburger-btn">
    <svg width="18" height="14" viewBox="0 0 18 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
      <line x1="0" y1="1" x2="18" y2="1"/>
      <line x1="0" y1="7" x2="18" y2="7"/>
      <line x1="0" y1="13" x2="18" y2="13"/>
    </svg>
  </button>
</nav>

<dialog id="mobile-menu" aria-label="Navigation menu">
  <div class="mobile-menu-header">
    <a href="/" class="nav-name">Aditya Raj Singh</a>
    <button class="mobile-close" aria-label="Close menu" id="mobile-close-btn">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="3" x2="15" y2="15"/>
        <line x1="15" y1="3" x2="3" y2="15"/>
      </svg>
    </button>
  </div>
  <nav class="mobile-nav">
    {navLinks.map(({ href, label }) => (
      <a href={href} class="mobile-nav-link">{label}</a>
    ))}
    <a href="mailto:hello@adityarsingh.in" class="mobile-nav-link">Contact</a>
    <a href="/cv/aditya-cv.pdf" class="mobile-nav-link" target="_blank" rel="noopener noreferrer">CV</a>
  </nav>
  <div class="mobile-footer">
    <a href="https://linkedin.com/in/adityar-singh/" class="mobile-social" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    <a href="https://github.com/adityarsingh" class="mobile-social" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="mailto:hello@adityarsingh.in" class="mobile-social">Email</a>
  </div>
</dialog>

<script>
  const hamburger = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu') as HTMLDialogElement | null;
  const closeBtn = document.getElementById('mobile-close-btn');

  hamburger?.addEventListener('click', () => {
    menu?.showModal();
    hamburger.setAttribute('aria-expanded', 'true');
  });

  closeBtn?.addEventListener('click', () => menu?.close());
  menu?.addEventListener('close', () => hamburger?.setAttribute('aria-expanded', 'false'));
  menu?.addEventListener('click', (e) => { if (e.target === menu) menu.close(); });
  menu?.querySelectorAll('a').forEach(link => link.addEventListener('click', () => menu.close()));

  // ── Theme toggle (light-first: default = no attr, dark = data-theme="dark") ──
  const themeToggle = document.getElementById('theme-toggle');

  function switchTheme() {
    const root = document.documentElement;
    const isDark = root.getAttribute('data-theme') === 'dark';

    root.style.setProperty('--theme-transition', '0.25s');
    root.classList.add('theme-switching');

    if (isDark) {
      root.removeAttribute('data-theme');
      root.style.colorScheme = 'light';
      localStorage.setItem('theme', 'light');
    } else {
      root.setAttribute('data-theme', 'dark');
      root.style.colorScheme = 'dark';
      localStorage.setItem('theme', 'dark');
    }

    setTimeout(() => {
      root.style.removeProperty('--theme-transition');
      root.classList.remove('theme-switching');
    }, 300);
  }

  themeToggle?.addEventListener('click', switchTheme);
</script>

<style>
.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 4px 22px;
}

.nav-name {
  font-size: 14px;
  font-weight: 600;
  letter-spacing: -0.025em;
  color: var(--color-ink);
  text-decoration: none;
}

.nav-links {
  display: flex;
  gap: 20px;
  align-items: center;
}

.nav-link {
  font-size: 13.5px;
  color: var(--color-body-text);
  text-decoration: none;
  letter-spacing: -0.01em;
  transition: color 0.1s;
}
.nav-link:hover  { color: var(--color-ink); }
.nav-link-active { color: var(--color-ink); font-weight: 500; }

/* Theme button — round circle */
.theme-btn {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 1px solid var(--color-hairline);
  background: transparent;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-mute);
  padding: 0;
  transition: color 0.1s, border-color 0.1s;
}
.theme-btn:hover { color: var(--color-body-text); border-color: var(--color-body-text); }

/* Light mode (default): show moon to switch to dark */
.icon-sun  { display: none; }
.icon-moon { display: block; }

/* Dark mode: show sun to switch to light */
html[data-theme="dark"] .icon-sun  { display: block; }
html[data-theme="dark"] .icon-moon { display: none; }

/* Hamburger */
.nav-hamburger {
  display: none;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: var(--radius-sm);
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-ink);
  padding: 0;
}
.nav-hamburger:hover { background-color: var(--color-canvas-soft-2); }

@media (max-width: 540px) {
  .nav-links    { display: none; }
  .nav-hamburger { display: flex; }
}

/* ── Mobile dialog ── */
#mobile-menu {
  position: fixed;
  inset: 0;
  width: 100%;
  max-width: 100%;
  height: 100%;
  max-height: 100%;
  margin: 0;
  padding: 0;
  border: none;
  background-color: var(--color-canvas);
  display: flex;
  flex-direction: column;
}
#mobile-menu:not([open]) { display: none; }
#mobile-menu::backdrop { background-color: rgba(0, 0, 0, 0.2); }

.mobile-menu-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60px;
  padding: 0 24px;
  border-bottom: 1px solid var(--color-hairline);
  flex-shrink: 0;
}

.mobile-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-ink);
  border-radius: var(--radius-sm);
  padding: 0;
}

.mobile-nav {
  display: flex;
  flex-direction: column;
  padding: 12px;
  flex: 1;
}
.mobile-nav-link {
  display: block;
  padding: 13px 16px;
  color: var(--color-ink);
  font-size: 17px;
  font-weight: 400;
  text-decoration: none;
  border-radius: var(--radius-md);
  transition: background-color 0.1s ease;
  letter-spacing: -0.01em;
}
.mobile-nav-link:hover { background-color: var(--color-canvas-soft-2); }

.mobile-footer {
  padding: 20px 28px;
  border-top: 1px solid var(--color-hairline);
  display: flex;
  gap: 20px;
  flex-shrink: 0;
}
.mobile-social {
  font-size: 13px;
  color: var(--color-mute);
  text-decoration: none;
  transition: color 0.1s ease;
  letter-spacing: -0.01em;
}
.mobile-social:hover { color: var(--color-ink); }
</style>
