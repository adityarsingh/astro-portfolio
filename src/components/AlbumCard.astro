---
import { formatDate } from '@/lib/formatDate';

interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  location: string;
  coverImage: string;
  coverAlt: string;
  imageCount: number;
}

const { slug, title, description, date, location, coverImage, coverAlt, imageCount } = Astro.props;
---

<a href={`/photos/${slug}`} class="album-card">
  <div class="album-cover">
    <img src={coverImage} alt={coverAlt} loading="lazy" />
    <div class="album-count text-caption-mono">{imageCount} photos</div>
  </div>
  <div class="album-info">
    <div class="album-meta text-caption-mono">
      <span>{location}</span>
      <span aria-hidden="true">·</span>
      <time datetime={date.toISOString()}>{formatDate(date, 'short')}</time>
    </div>
    <h2 class="text-display-sm album-title">{title}</h2>
    <p class="text-body-sm album-desc">{description}</p>
  </div>
</a>

<style>
.album-card {
  display: block;
  text-decoration: none;
  color: inherit;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background-color: var(--color-canvas);
  box-shadow: var(--shadow-2);
  transition: box-shadow 0.15s ease, transform 0.15s ease;
}
.album-card:hover {
  box-shadow: var(--shadow-4);
  transform: translateY(-2px);
}
.album-cover {
  position: relative;
  aspect-ratio: 3/2;
  overflow: hidden;
  background-color: var(--color-canvas-soft-2);
}
.album-cover img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}
.album-card:hover .album-cover img { transform: scale(1.03); }
.album-count {
  position: absolute;
  bottom: 10px;
  right: 10px;
  background-color: rgba(23, 23, 23, 0.75);
  color: #fff;
  padding: 3px 8px;
  border-radius: var(--radius-full);
  font-size: 11px;
}
.album-info {
  padding: var(--spacing-md);
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.album-meta {
  display: flex;
  gap: 6px;
  color: var(--color-mute);
}
.album-title { color: var(--color-ink); }
.album-desc  { color: var(--color-body-text); }
</style>
