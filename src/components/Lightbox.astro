---
---

<dialog id="lightbox" aria-label="Photo lightbox" aria-modal="true">

  <!-- Top bar -->
  <div class="lb-topbar">
    <span id="lb-counter" class="lb-counter"></span>
    <button id="lb-close" class="lb-icon-btn" aria-label="Close lightbox">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="3" y1="3" x2="15" y2="15"/>
        <line x1="15" y1="3" x2="3" y2="15"/>
      </svg>
    </button>
  </div>

  <!-- Image stage -->
  <div class="lb-stage" id="lb-stage">
    <div class="lb-spinner" id="lb-spinner" aria-hidden="true"></div>
    <figure class="lb-figure">
      <img id="lb-img" src="" alt="" />
      <figcaption id="lb-caption" class="lb-caption"></figcaption>
    </figure>
  </div>

  <!-- Side arrows -->
  <button id="lb-prev" class="lb-arrow lb-arrow-prev" aria-label="Previous photo">
    <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="14 4 8 11 14 18"/>
    </svg>
  </button>
  <button id="lb-next" class="lb-arrow lb-arrow-next" aria-label="Next photo">
    <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="8 4 14 11 8 18"/>
    </svg>
  </button>

</dialog>

<script>
  interface LbImage { src: string; alt: string; caption?: string; }

  const dialog  = document.getElementById('lightbox') as HTMLDialogElement | null;
  const imgEl   = document.getElementById('lb-img')      as HTMLImageElement | null;
  const caption = document.getElementById('lb-caption');
  const counter = document.getElementById('lb-counter');
  const spinner = document.getElementById('lb-spinner');
  const prevBtn = document.getElementById('lb-prev');
  const nextBtn = document.getElementById('lb-next');

  let images: LbImage[] = [];
  let current = 0;

  // ── Preload a single image URL in the background ──
  function preload(src: string) {
    const img = new Image();
    img.src = src;
  }

  // ── Navigate to a given index ──
  function show(index: number) {
    current = (index + images.length) % images.length;
    const item = images[current];

    // Update counter
    if (counter) counter.textContent = `${current + 1} / ${images.length}`;

    // Fade out, swap src, fade in on load
    if (imgEl) {
      imgEl.style.opacity = '0';
      if (spinner) spinner.style.opacity = '1';

      const onLoad = () => {
        imgEl.style.opacity = '1';
        if (spinner) spinner.style.opacity = '0';
        imgEl.removeEventListener('load', onLoad);
      };
      imgEl.addEventListener('load', onLoad);
      imgEl.src = item.src;
      imgEl.alt = item.alt;
    }

    if (caption) caption.textContent = item.caption ?? '';

    // Show/hide arrows at ends (no wrapping visually)
    if (prevBtn) prevBtn.style.visibility = current === 0 ? 'hidden' : 'visible';
    if (nextBtn) nextBtn.style.visibility = current === images.length - 1 ? 'hidden' : 'visible';

    // Preload neighbours
    if (current + 1 < images.length) preload(images[current + 1].src);
    if (current - 1 >= 0)            preload(images[current - 1].src);
  }

  // ── Open lightbox when a grid item is clicked ──
  document.addEventListener('click', (e) => {
    const el = (e.target as HTMLElement).closest('[data-lightbox-index]') as HTMLElement | null;
    if (!el) return;
    e.preventDefault();
    const grid = el.closest('[data-lightbox-images]') as HTMLElement | null;
    images = grid ? JSON.parse(grid.dataset.lightboxImages ?? '[]') : [];
    show(parseInt(el.dataset.lightboxIndex ?? '0', 10));
    dialog?.showModal();
  });

  // ── Button handlers ──
  document.getElementById('lb-close')?.addEventListener('click', () => dialog?.close());
  prevBtn?.addEventListener('click', () => show(current - 1));
  nextBtn?.addEventListener('click', () => show(current + 1));

  // ── Close on backdrop click ──
  dialog?.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });

  // ── Keyboard ──
  document.addEventListener('keydown', (e) => {
    if (!dialog?.open) return;
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); show(current - 1); }
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown')  { e.preventDefault(); show(current + 1); }
    if (e.key === 'Escape') dialog.close();
  });

  // ── Touch / swipe support ──
  let touchStartX = 0;
  dialog?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });
  dialog?.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) < 40) return;
    if (dx < 0) show(current + 1);
    else        show(current - 1);
  }, { passive: true });
</script>

<style>
/* ── Full-viewport dialog ── */
#lightbox {
  position: fixed;
  inset: 0;
  width: 100%;
  max-width: 100%;
  height: 100%;
  max-height: 100%;
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
#lightbox:not([open]) { display: none; }
#lightbox::backdrop {
  background: rgba(0, 0, 0, 0.93);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

/* ── Top bar ── */
.lb-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px 10px;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}
.lb-counter {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  color: rgba(255, 255, 255, 0.45);
}
.lb-icon-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  cursor: pointer;
  color: rgba(255, 255, 255, 0.75);
  transition: background 0.15s, color 0.15s;
  padding: 0;
}
.lb-icon-btn:hover { background: rgba(255, 255, 255, 0.16); color: #fff; }

/* ── Image stage ── */
.lb-stage {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0 72px;
  min-height: 0;
}
.lb-figure {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  max-width: 100%;
  max-height: 100%;
}
#lb-img {
  max-width: 100%;
  max-height: calc(100vh - 130px);
  width: auto;
  height: auto;
  object-fit: contain;
  border-radius: 6px;
  display: block;
  opacity: 1;
  transition: opacity 0.2s ease;
}
.lb-caption {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.05em;
  color: rgba(255, 255, 255, 0.45);
  text-align: center;
  min-height: 14px;
}

/* ── Loading spinner ── */
.lb-spinner {
  position: absolute;
  width: 28px;
  height: 28px;
  border: 2px solid rgba(255, 255, 255, 0.15);
  border-top-color: rgba(255, 255, 255, 0.7);
  border-radius: 50%;
  opacity: 0;
  transition: opacity 0.15s;
  animation: lb-spin 0.7s linear infinite;
  pointer-events: none;
}
@keyframes lb-spin { to { transform: rotate(360deg); } }

/* ── Side arrows ── */
.lb-arrow {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 50%;
  cursor: pointer;
  color: rgba(255, 255, 255, 0.75);
  transition: background 0.15s, color 0.15s, transform 0.15s;
  padding: 0;
  z-index: 10;
}
.lb-arrow:hover {
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
}
.lb-arrow-prev {
  left: 14px;
  transform: translateY(-50%);
}
.lb-arrow-next {
  right: 14px;
  transform: translateY(-50%);
}
.lb-arrow-prev:hover { transform: translateY(-50%) translateX(-2px); }
.lb-arrow-next:hover { transform: translateY(-50%) translateX(2px); }

/* ── Mobile adjustments ── */
@media (max-width: 540px) {
  .lb-stage { padding: 0 52px; }
  .lb-arrow { width: 40px; height: 40px; }
  .lb-arrow-prev { left: 8px; }
  .lb-arrow-next { right: 8px; }
  #lb-img { max-height: calc(100vh - 110px); }
}
</style>
