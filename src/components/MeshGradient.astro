---
interface Props {
  opacity?: number;
}
const { opacity = 0.18 } = Astro.props;
---

<div
  class="mesh-gradient"
  aria-hidden="true"
  style={`opacity: ${opacity}`}
></div>

<style>
.mesh-gradient {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background:
    radial-gradient(ellipse 70% 60% at 20% 0%, rgba(0, 124, 240, 0.6) 0%, transparent 60%),
    radial-gradient(ellipse 60% 50% at 80% 10%, rgba(0, 223, 216, 0.5) 0%, transparent 55%),
    radial-gradient(ellipse 50% 60% at 50% 30%, rgba(121, 40, 202, 0.4) 0%, transparent 60%),
    radial-gradient(ellipse 55% 45% at 15% 60%, rgba(255, 0, 128, 0.35) 0%, transparent 55%),
    radial-gradient(ellipse 45% 50% at 85% 50%, rgba(255, 77, 77, 0.3) 0%, transparent 55%),
    radial-gradient(ellipse 60% 40% at 60% 80%, rgba(249, 203, 40, 0.25) 0%, transparent 50%);
}
</style>
