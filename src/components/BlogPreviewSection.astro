---
import BlogCard from './BlogCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props;
---

<section class="blog-preview">
  <div class="blog-preview-inner">
    <div class="section-header">
      <span class="text-caption-mono section-eyebrow">Writing</span>
      <h2 class="text-display-lg">Recent posts.</h2>
    </div>
    <div class="blog-preview-grid">
      {posts.map(post => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.slug}
          tags={post.data.tags}
        />
      ))}
    </div>
    <div class="blog-preview-more">
      <a href="/blog" class="btn-secondary">View all posts →</a>
    </div>
  </div>
</section>

<style>
.blog-preview {
  background-color: var(--color-canvas-soft);
  padding: var(--spacing-5xl) 0;
  border-top: 1px solid var(--color-hairline);
}
.blog-preview-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  flex-direction: column;
  gap: 40px;
}
.section-header {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.section-eyebrow { color: var(--color-mute); }
.blog-preview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
@media (max-width: 960px) { .blog-preview-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .blog-preview-grid { grid-template-columns: 1fr; } }
.blog-preview-more {
  display: flex;
}
</style>
