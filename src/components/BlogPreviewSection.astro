---
import { formatDate } from '@/lib/formatDate';
import { readingTime } from '@/lib/readingTime';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props;
---

<section class="card writing-card">
  <span class="eyebrow">Writing</span>
  <h2 class="section-title">Latest posts.</h2>

  <div class="blog-cards">
    {posts.map(post => (
      <a href={`/blog/${post.slug}/`} class="blog-card-item">
        <div class="blog-card-meta">
          <span>{formatDate(post.data.date, 'short')}</span>
          <span>·</span>
          <span>{post.data.tags[0] ?? ''}</span>
        </div>
        <div class="blog-card-title">{post.data.title}</div>
        <div class="blog-card-desc">{post.data.description}</div>
        <div class="blog-card-read">{readingTime(post.body ?? '')} min read</div>
      </a>
    ))}
  </div>

  <div class="writing-footer">
    <a href="/blog/" class="view-all">View all writing →</a>
  </div>
</section>

<style>
.writing-card {
  padding: var(--card-py) var(--card-px) 0;
}

.blog-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--color-hairline);
  border-top: 1px solid var(--color-hairline);
  margin: 0 calc(-1 * var(--card-px)) 28px;
}

.blog-card-item {
  background: var(--color-canvas-soft);
  padding: 28px var(--card-px);
  display: flex;
  flex-direction: column;
  gap: 10px;
  text-decoration: none;
  color: inherit;
  transition: background-color 0.1s;
}
.blog-card-item:hover { background: var(--color-canvas); }

.blog-card-meta {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--color-mute);
  display: flex;
  gap: 8px;
}

.blog-card-title {
  font-size: 14px;
  font-weight: 600;
  letter-spacing: -0.025em;
  line-height: 1.35;
  color: var(--color-ink);
}

.blog-card-desc {
  font-size: 12.5px;
  line-height: 1.62;
  color: var(--color-body-text);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.blog-card-read {
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--color-mute);
  margin-top: auto;
  padding-top: 6px;
}

.writing-footer {
  padding-bottom: var(--card-py);
}

.view-all {
  font-size: 13px;
  font-weight: 500;
  color: var(--color-ink);
  text-decoration: none;
  letter-spacing: -0.01em;
  transition: opacity 0.1s;
}
.view-all:hover { opacity: 0.65; }

@media (max-width: 860px) {
  .blog-cards { grid-template-columns: 1fr; margin: 0 calc(-1 * var(--card-px)) 24px; }
}

@media (max-width: 540px) {
  .writing-card   { padding: 28px 24px 0; }
  .blog-cards     { margin: 0 -24px 20px; }
  .blog-card-item { padding: 24px 24px; }
}
</style>
