---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Pagination from '@/components/Pagination.astro';
import JsonLd from '@/components/JsonLd.astro';
import { getCollection } from 'astro:content';
import { getSortedTags } from '@/lib/getTagCounts';
import { formatDate } from '@/lib/formatDate';
import { readingTime } from '@/lib/readingTime';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(posts, { pageSize: 50 });
};

const { page } = Astro.props;
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const sortedTags = getSortedTags(allPosts).slice(0, 10);
const uniqueTagCount = new Set(allPosts.flatMap(p => p.data.tags)).size;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adityarsingh.in';
const avgMins = allPosts.length > 0
  ? Math.round(allPosts.reduce((sum, p) => sum + readingTime(p.body ?? ''), 0) / allPosts.length)
  : 6;
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${siteUrl}/blog/` },
  ],
};

// Group posts by year for year separators
const postsByYear = page.data.reduce((acc, post) => {
  const year = post.data.date.getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<string, typeof page.data>);

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout
  title={`Blog${page.currentPage > 1 ? ` — Page ${page.currentPage}` : ''}`}
  description="Notes on AI, automation, and building better systems — plus occasional side projects and travel."
  noindex={page.currentPage > 1}
>
  <JsonLd slot="head" schema={breadcrumbSchema} />

  <div class="cards">

    <!-- Header card -->
    <div class="card header-card">
      <span class="eyebrow">Writing</span>
      <h1>Blog.</h1>
      <p>Notes on AI, automation, and building better systems — plus occasional side projects and travel.</p>
      <div class="header-meta">
        <div class="meta-item">
          <span class="meta-num">{allPosts.length}</span>
          <span class="meta-label">Posts</span>
        </div>
        <div class="meta-divider" aria-hidden="true"></div>
        <div class="meta-item">
          <span class="meta-num">{uniqueTagCount}</span>
          <span class="meta-label">Topics</span>
        </div>
        <div class="meta-divider" aria-hidden="true"></div>
        <div class="meta-item">
          <span class="meta-num">~{avgMins}</span>
          <span class="meta-label">Min avg</span>
        </div>
      </div>
    </div>

    <!-- Tag filter -->
    {sortedTags.length > 0 && (
      <div class="tag-filter" id="tag-filter" role="navigation" aria-label="Filter by topic">
        <button class="tag-pill active" data-tag="all">All</button>
        {sortedTags.map(([tag]) => (
          <button class="tag-pill" data-tag={tag}>{tag}</button>
        ))}
      </div>
    )}

    <!-- Posts list -->
    <div class="card posts-card">
      <div id="posts-list">
        {years.map(year => (
          <>
            <div class="year-sep" data-year={year}>{year}</div>
            {postsByYear[year].map(post => (
              <a
                href={`/blog/${post.slug}/`}
                class="post-row"
                data-tags={JSON.stringify(post.data.tags)}
                data-year={year}
              >
                <span class="post-date">{formatDate(post.data.date, 'short')}</span>
                <span class="post-title">{post.data.title}</span>
                <span class="post-tag">{post.data.tags[0] ?? ''}</span>
                <span class="post-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </>
        ))}
      </div>
      <div class="empty-state" id="empty-state" hidden>
        No posts with that tag yet.
      </div>
    </div>

    <Pagination
      currentPage={page.currentPage}
      totalPages={page.lastPage}
      baseUrl="/blog/"
    />
  </div>
</BaseLayout>

<script>
  const filterEl = document.getElementById('tag-filter');
  const emptyState = document.getElementById('empty-state');

  filterEl?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-tag]') as HTMLElement | null;
    if (!btn) return;

    filterEl.querySelectorAll('[data-tag]').forEach(b => {
      b.classList.remove('active');
      b.setAttribute('aria-pressed', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-pressed', 'true');

    const tag = btn.dataset.tag ?? 'all';
    const rows = document.querySelectorAll<HTMLElement>('.post-row');
    const seps  = document.querySelectorAll<HTMLElement>('.year-sep');
    let visible = 0;

    rows.forEach(row => {
      const tags: string[] = JSON.parse(row.dataset.tags ?? '[]');
      const show = tag === 'all' || tags.includes(tag);
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    seps.forEach(sep => {
      const year = sep.dataset.year ?? '';
      const hasVisible = Array.from(document.querySelectorAll<HTMLElement>(`.post-row[data-year="${year}"]`))
        .some(r => r.style.display !== 'none');
      sep.style.display = hasVisible ? '' : 'none';
    });

    if (emptyState) emptyState.hidden = visible > 0;
  });
</script>

<style>
.header-card {
  padding: 40px 40px 36px;
}

.header-card h1 {
  font-size: 38px;
  font-weight: 600;
  letter-spacing: -0.04em;
  line-height: 1.1;
  color: var(--color-ink);
  margin-bottom: 12px;
}

.header-card p {
  font-size: 14.5px;
  line-height: 1.7;
  color: var(--color-body-text);
  max-width: 420px;
  margin-bottom: 24px;
}

.header-meta {
  display: flex;
  align-items: center;
  gap: 20px;
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.meta-num {
  font-size: 20px;
  font-weight: 600;
  letter-spacing: -0.04em;
  color: var(--color-ink);
  line-height: 1;
}

.meta-label {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-mute);
}

.meta-divider {
  width: 1px;
  height: 28px;
  background: var(--color-hairline);
}

/* ── Tag filter ── */
.tag-filter {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  padding: 2px 0;
}

/* ── Posts card ── */
.posts-card { overflow: hidden; }

.year-sep {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-mute);
  padding: 22px 40px 10px;
  border-bottom: 1px solid var(--color-hairline);
}

.post-row {
  display: grid;
  grid-template-columns: 72px 1fr minmax(0, 120px) 18px;
  gap: 20px;
  align-items: center;
  padding: 15px 40px;
  border-bottom: 1px solid var(--color-hairline);
  text-decoration: none;
  color: inherit;
  transition: background-color 0.1s;
}
.post-row:hover   { background: var(--color-canvas); }
.post-row:last-child { border-bottom: none; padding-bottom: 24px; }

.post-date {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.04em;
  color: var(--color-mute);
  white-space: nowrap;
}

.post-title {
  font-size: 13.5px;
  font-weight: 500;
  letter-spacing: -0.015em;
  line-height: 1.42;
  color: var(--color-ink);
}

.post-tag {
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--color-mute);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.post-arrow { font-size: 12px; color: var(--color-mute); text-align: right; }

.empty-state {
  padding: 48px 40px;
  font-size: 13px;
  color: var(--color-mute);
  font-style: italic;
  text-align: center;
}

@media (max-width: 540px) {
  .tag-filter {
    flex-wrap: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 4px;
    scrollbar-width: none;
  }
  .tag-filter::-webkit-scrollbar { display: none; }

  .header-card { padding: 28px 24px 24px; }
  .year-sep    { padding: 18px 20px 8px; }

  .post-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 3px;
    padding: 14px 20px;
    position: relative;
  }
  .post-date  { font-size: 10px; }
  .post-title { padding-right: 20px; }
  .post-tag   { display: none; }
  .post-arrow {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
  }
}
</style>
