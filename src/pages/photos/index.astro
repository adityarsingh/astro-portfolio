---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AlbumCard from '@/components/AlbumCard.astro';
import JsonLd from '@/components/JsonLd.astro';
import { getCollection } from 'astro:content';

const albums = (await getCollection('photos'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adityarsingh.com';
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Photos", "item": `${siteUrl}/photos` },
  ],
};
---

<BaseLayout
  title="Photos"
  description="Travel photography from Rajasthan, Vietnam, Bramhatal Trek, Nepal, and beyond."
>
  <JsonLd slot="head" schema={breadcrumbSchema} />

  <div class="photos-page">
    <div class="index-header">
      <span class="eyebrow">Photography</span>
      <h1>Travels with a camera.</h1>
      <p>Rajasthan, Vietnam, the Himalayas — and counting.</p>
    </div>

    {albums.length === 0 ? (
      <p class="no-albums">Albums coming soon.</p>
    ) : (
      <div class="albums-grid">
        {albums.map(album => (
          <AlbumCard
            slug={album.id}
            title={album.data.title}
            description={album.data.description}
            date={album.data.date}
            location={album.data.location}
            coverImage={album.data.coverImage}
            coverAlt={album.data.coverAlt}
            imageCount={album.data.images.length}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
.photos-page {
  max-width: 1200px;
  margin: 0 auto;
}

.index-header {
  padding: 8px 4px 32px;
}

.index-header h1 {
  font-size: clamp(28px, 5vw, 38px);
  font-weight: 600;
  letter-spacing: -0.04em;
  color: var(--color-ink);
  margin-top: 8px;
  margin-bottom: 8px;
}

.index-header p {
  font-size: 15px;
  color: var(--color-body-text);
  line-height: 1.6;
}

.albums-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

@media (min-width: 900px)  { .albums-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 680px)  { .albums-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 440px)  { .albums-grid { grid-template-columns: 1fr; } }

.no-albums {
  font-size: 14px;
  color: var(--color-mute);
  font-style: italic;
}
</style>
