---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import SuperpowersSection from '@/components/SuperpowersSection.astro';
import AboutSection from '@/components/AboutSection.astro';
import BlogPreviewSection from '@/components/BlogPreviewSection.astro';
import JsonLd from '@/components/JsonLd.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adityarsingh.com';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Aditya Raj Singh",
  "url": siteUrl,
  "email": "hello@adityarsingh.in",
  "sameAs": [
    "https://github.com/adityarsingh",
    "https://linkedin.com/in/adityar-singh/",
  ],
  "jobTitle": "Content & Automation Engineer",
  "description": "I make content easier to find, manage, and scale. At Akamai, that means working across AI agents, search strategy, and content ops to keep the website running well and ranking higher.",
  "worksFor": {
    "@type": "Organization",
    "name": "Akamai",
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
  ],
};
---

<BaseLayout
  title="Aditya Raj Singh — SEO, GEO & AI Automation | Marketing at Akamai"
  description="I make content easier to find, manage, and scale. At Akamai, that means working across AI agents, search strategy, and content ops to keep the website ranking."
>
  <JsonLd slot="head" schema={[personSchema, breadcrumbSchema]} />

  <div class="cards">
    <HeroSection />
    <SuperpowersSection />
    <AboutSection />
    {posts.length > 0 && <BlogPreviewSection posts={posts} />}

    <div class="cta-card">
      <div class="cta-text">
        <strong>Let's work together.</strong>
      </div>
      <a href="mailto:hello@adityarsingh.in" class="btn-cta">Send a message →</a>
    </div>
  </div>
</BaseLayout>

<style>
.cta-card {
  background: var(--color-cta-bg);
  border-radius: var(--radius-card);
  padding: 44px var(--card-px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}

.cta-text {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.cta-text strong {
  font-size: 20px;
  font-weight: 600;
  letter-spacing: -0.03em;
  color: var(--color-cta-fg);
}
.cta-text span {
  font-size: 13px;
  color: var(--color-cta-sub);
  letter-spacing: -0.01em;
}

@media (max-width: 540px) {
  .cta-card { flex-direction: column; align-items: flex-start; gap: 20px; padding: 32px 24px; }
}
</style>
