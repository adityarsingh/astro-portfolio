---
import BaseLayout from './BaseLayout.astro';
import JsonLd from '@/components/JsonLd.astro';
import TagPill from '@/components/TagPill.astro';
import { formatDate } from '@/lib/formatDate';
import { readingTime } from '@/lib/readingTime';

interface PostNavEntry {
  slug: string;
  data: { title: string };
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags: string[];
  coverImage?: string;
  coverAlt?: string;
  slug: string;
  rawContent: string;
  prevPost?: PostNavEntry | null;
  nextPost?: PostNavEntry | null;
}

const { title, description, date, updated, tags, coverImage, coverAlt, slug, rawContent, prevPost, nextPost } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adityarsingh.in';
const pageUrl = `${siteUrl}/blog/${slug}/`;
const mins = readingTime(rawContent);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date.toISOString(),
  "dateModified": (updated ?? date).toISOString(),
  "url": pageUrl,
  "image": coverImage ? `${siteUrl}${coverImage}` : `${siteUrl}/og/default.png`,
  "author": {
    "@type": "Person",
    "name": "Aditya Raj Singh",
    "url": siteUrl,
  },
  "publisher": {
    "@type": "Person",
    "name": "Aditya Raj Singh",
    "url": siteUrl,
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${siteUrl}/blog/` },
    { "@type": "ListItem", "position": 3, "name": title, "item": pageUrl },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  og={{ type: 'article', image: coverImage, imageAlt: coverAlt }}
  canonical={pageUrl}
>
  <JsonLd slot="head" schema={[articleSchema, breadcrumbSchema]} />

  <div class="blog-post-layout">
    <article class="blog-post-article">
      <!-- Breadcrumb -->
      <nav class="post-breadcrumb" aria-label="Breadcrumb">
        <a href="/blog/" class="post-breadcrumb-link">← Blog</a>
      </nav>

      <!-- Post header -->
      <header class="post-header">
        <div class="post-meta">
          <time datetime={date.toISOString()} class="text-caption-mono">
            {formatDate(date, 'long')}
          </time>
          <span class="post-meta-sep" aria-hidden="true">·</span>
          <span class="text-caption-mono">{mins} min read</span>
        </div>
        <h1 class="text-display-lg post-title">{title}</h1>
        <p class="text-body-lg post-description">{description}</p>
      </header>

      {coverImage && (
        <div class="post-cover">
          <img src={coverImage} alt={coverAlt ?? title} loading="eager" />
        </div>
      )}

      <div class="prose">
        <slot />
      </div>

      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map(tag => <TagPill tag={tag} />)}
        </div>
      )}

      {(prevPost || nextPost) && (
        <nav class="post-nav" aria-label="Post navigation">
          <div class="post-nav-item post-nav-item--prev">
            {prevPost && (
              <a href={`/blog/${prevPost.slug}`} class="post-nav-link">
                <span class="post-nav-dir">← Older</span>
                <span class="post-nav-title">{prevPost.data.title}</span>
              </a>
            )}
          </div>
          <div class="post-nav-item post-nav-item--next">
            {nextPost && (
              <a href={`/blog/${nextPost.slug}`} class="post-nav-link post-nav-link--right">
                <span class="post-nav-dir">Newer →</span>
                <span class="post-nav-title">{nextPost.data.title}</span>
              </a>
            )}
          </div>
        </nav>
      )}
    </article>
  </div>
</BaseLayout>

<style>
.blog-post-layout {
  max-width: 768px;
  margin: 0 auto;
  padding: 48px 24px 96px;
}
.blog-post-article {
  display: flex;
  flex-direction: column;
  gap: 32px;
}
.post-breadcrumb { margin-bottom: -16px; }
.post-breadcrumb-link {
  font-size: 13px;
  color: var(--color-mute);
  text-decoration: none;
  letter-spacing: -0.01em;
  transition: color 0.1s;
}
.post-breadcrumb-link:hover { color: var(--color-ink); }
.post-header {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.post-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--color-mute);
}
.post-meta-sep {
  color: var(--color-hairline-strong);
}
.post-title {
  color: var(--color-ink);
}
.post-description {
  color: var(--color-body-text);
}
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.post-cover {
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-3);
}
.post-cover img {
  width: 100%;
  height: auto;
  display: block;
}

/* Prev / next navigation */
.post-nav {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  padding-top: 24px;
  border-top: 1px solid var(--color-hairline);
}
.post-nav-item--next { text-align: right; }
.post-nav-link {
  display: inline-flex;
  flex-direction: column;
  gap: 5px;
  text-decoration: none;
  color: inherit;
}
.post-nav-link--right { align-items: flex-end; }
.post-nav-dir {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--color-mute);
}
.post-nav-title {
  font-size: 13.5px;
  font-weight: 500;
  color: var(--color-ink);
  letter-spacing: -0.015em;
  line-height: 1.35;
  transition: opacity 0.1s;
}
.post-nav-link:hover .post-nav-title { opacity: 0.65; }

@media (max-width: 540px) {
  .post-nav { grid-template-columns: 1fr; }
  .post-nav-item--next { text-align: left; }
  .post-nav-link--right { align-items: flex-start; }
}
</style>
