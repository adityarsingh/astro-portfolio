---
import SEO from '@/components/SEO.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  og?: {
    type?: 'website' | 'article';
    image?: string;
    imageAlt?: string;
  };
  noindex?: boolean;
}

const { title, description, canonical, og, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Apply saved theme before first paint to prevent flash.
         data-cfasync="false" stops Cloudflare Rocket Loader from deferring
         this script — without it the script runs on window.load (after all
         images download) and the page flashes light mode the whole time. -->
    <script is:inline data-cfasync="false">
      (function () {
        var stored = localStorage.getItem('theme');
        // Default is light (warm cream) — only apply dark when user chose it
        if (stored === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
          document.documentElement.style.colorScheme = 'dark';
        } else {
          document.documentElement.style.colorScheme = 'light';
        }
      })();
    </script>
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Aditya Raj Singh — Blog" href="/rss.xml" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      og={og}
      noindex={noindex}
    />
    <slot name="head" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0SB7YZPSF7"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0SB7YZPSF7');
    </script>
  </head>
  <body>
    <div class="pg">
      <Nav />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
